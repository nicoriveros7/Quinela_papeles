{
  "name": "quinela-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @quinela/web --filter @quinela/api dev",
    "dev:web": "pnpm --filter @quinela/web dev",
    "dev:api": "pnpm --filter @quinela/api dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @quinela/db db:generate",
    "db:migrate": "pnpm --filter @quinela/db db:migrate",
    "db:seed": "pnpm --filter @quinela/db db:seed"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
